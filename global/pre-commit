#!/bin/bash
# ai-coding-safety — Global Pre-commit Hook
# Blocks sensitive files and credential patterns across ALL repositories.
# Install: git config --global core.hooksPath ~/.githooks

echo "🔍 [Global] 보안 검사 중..."

FAILED=0

# ── 1. Private key files ───────────────────────────────────────
BLOCKED_EXT=$(git diff --cached --name-only | grep -E "\.(pem|key|p12|pfx|pri|ppk)$|(^|/)id_(rsa|dsa|ecdsa|ed25519)(\.pub)?$")
if [ -n "$BLOCKED_EXT" ]; then
  echo ""
  echo "❌ 개인키/인증서 파일 커밋 차단:"
  echo "$BLOCKED_EXT" | sed 's/^/   /'
  FAILED=1
fi

# ── 2. .env files with real values ────────────────────────────
ENV_FILES=$(git diff --cached --name-only | grep -E "(^|/)\.env(\..+)?$")
if [ -n "$ENV_FILES" ]; then
  echo ""
  echo "❌ .env 파일 커밋 차단:"
  echo "$ENV_FILES" | sed 's/^/   /'
  echo "   💡 .env.example 을 대신 사용하세요."
  FAILED=1
fi

# ── 3. Token cache / secret files ─────────────────────────────
SECRET_FILES=$(git diff --cached --name-only | grep -E "(secret|credential|token_cache|\.token)\.(json|yaml|yml|txt)$")
if [ -n "$SECRET_FILES" ]; then
  echo ""
  echo "❌ 시크릿/토큰 파일 커밋 차단:"
  echo "$SECRET_FILES" | sed 's/^/   /'
  FAILED=1
fi

# ── 4. Common credential patterns in file content ─────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(py|js|ts|go|rb|java|yaml|yml|json|toml|env|sh|md)$")

# CI/CD 비대화형 환경 감지 (TTY 없으면 자동 차단)
_interactive_check() {
  if [ -t 0 ]; then
    read -p "   실제 비밀값이 아닌가요? 계속 진행하시겠습니까? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      FAILED=1
    fi
  else
    echo "   [비대화형 환경] 자동 차단합니다."
    FAILED=1
  fi
}

if [ -n "$STAGED" ]; then
  # GitHub Personal Access Token (classic)
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "ghp_[a-zA-Z0-9]{36}"; then
    echo ""
    echo "⚠️  GitHub Personal Access Token 패턴 발견 (ghp_...)"
    FAILED=1
  fi

  # GitHub Fine-grained PAT
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "github_pat_[a-zA-Z0-9_]{50,}"; then
    echo ""
    echo "⚠️  GitHub Fine-grained PAT 패턴 발견 (github_pat_...)"
    FAILED=1
  fi

  # OpenAI API Key (legacy sk-)
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "sk-[a-zA-Z0-9]{32,}"; then
    echo ""
    echo "⚠️  OpenAI API Key 패턴 발견 (sk-...)"
    FAILED=1
  fi

  # OpenAI Project Key (sk-proj-)
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "sk-proj-[a-zA-Z0-9_-]{50,}"; then
    echo ""
    echo "⚠️  OpenAI Project API Key 패턴 발견 (sk-proj-...)"
    FAILED=1
  fi

  # AWS Access Key
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "AKIA[0-9A-Z]{16}"; then
    echo ""
    echo "⚠️  AWS Access Key 패턴 발견 (AKIA...)"
    FAILED=1
  fi

  # Anthropic API Key
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "sk-ant-[a-zA-Z0-9-]{32,}"; then
    echo ""
    echo "⚠️  Anthropic API Key 패턴 발견 (sk-ant-...)"
    FAILED=1
  fi

  # Google / Gemini API Key
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "AIza[0-9A-Za-z_-]{35}"; then
    echo ""
    echo "⚠️  Google/Gemini API Key 패턴 발견 (AIza...)"
    FAILED=1
  fi

  # Stripe Secret Key
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "sk_live_[a-zA-Z0-9]{24,}"; then
    echo ""
    echo "⚠️  Stripe Secret Key 패턴 발견 (sk_live_...)"
    FAILED=1
  fi

  # HuggingFace Token
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qE "hf_[a-zA-Z0-9]{30,}"; then
    echo ""
    echo "⚠️  HuggingFace Token 패턴 발견 (hf_...)"
    FAILED=1
  fi

  # Generic high-entropy strings in assignments (password = "xxxxx")
  if git diff --cached | grep "^+" | grep -v "^+++" | grep -qiE "(password|passwd|secret|token)\s*[=:]\s*['\"][a-zA-Z0-9+/]{20,}['\"]"; then
    echo ""
    echo "⚠️  하드코딩된 패스워드/시크릿 패턴 발견"
    git diff --cached | grep "^+" | grep -v "^+++" | grep -iE "(password|passwd|secret|token)\s*[=:]\s*['\"][a-zA-Z0-9+/]{20,}['\"]" | head -3 | sed 's/^/   /'
    echo ""
    _interactive_check
  fi
fi

# ── 5. Call project-level pre-commit if exists ────────────────
PROJECT_HOOK="$(git rev-parse --show-toplevel 2>/dev/null)/.githooks/pre-commit"
if [ -f "$PROJECT_HOOK" ] && [ "$(git config core.hooksPath)" != "$HOME/.githooks" ]; then
  # Already using project hooks — skip to avoid double execution
  :
elif [ -f "$PROJECT_HOOK" ]; then
  bash "$PROJECT_HOOK"
  PROJECT_EXIT=$?
  if [ $PROJECT_EXIT -ne 0 ]; then
    exit $PROJECT_EXIT
  fi
fi

# ── Result ────────────────────────────────────────────────────
echo ""
if [ "$FAILED" -eq 1 ]; then
  echo "❌ 보안 검사 실패 — 커밋이 차단되었습니다."
  echo "   민감 정보를 제거하거나 .gitignore에 추가하세요."
  echo "   긴급 우회: git commit --no-verify  (주의: 보안 검사 생략됨)"
  exit 1
fi

echo "✅ [Global] 보안 검사 통과"
echo ""
exit 0
